# Dropbox OAuth 2.0
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Opcional
DROPBOX_FOLDER_PATH=/
DROPBOX_FILE_EXTENSION=.xlsx

# Sincronização
UPDATE_INTERVAL_MINUTES=5
STALE_THRESHOLD_HOURS=6

# Banco de dados (será substituído pela variável de sistema DATABASE_URL se existir)
DATABASE_URL=sqlite:///./icb_dashboard.db
